&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НастроитьДиаграмму();
	
	Если Не Параметры.Свойство("АдресДанныхГрафика") Или ПустаяСтрока(Параметры.АдресДанныхГрафика) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеГрафика = ПолучитьИзВременногоХранилища(Параметры.АдресДанныхГрафика);
	Если ДанныеГрафика = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьДиаграмму(ДанныеГрафика);
	
КонецПроцедуры

&НаСервере
Процедура НастроитьДиаграмму()
	
	Диаграмма.Обновление = Ложь;
	Диаграмма.Очистить();
	Диаграмма.ТипДиаграммы = ТипДиаграммы.Гистограмма;
	Диаграмма.ОбластьЛегенды.Расположение = РасположениеЛегендыДиаграммы.Нет;
	Диаграмма.ОбластьЗаголовка.Расположение = РасположениеОбластиЗаголовкаДиаграммы.Нет;
	Диаграмма.ОбластьПостроения.ОтображатьЛинииЗначенийШкалы = Истина;
	Диаграмма.АвтоМаксимальноеЗначение = Истина;
	Диаграмма.АвтоМинимальноеЗначение = Истина;
	Диаграмма.БазовоеЗначение = 0;
	Диаграмма.ПропускатьБазовоеЗначение = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДиаграмму(ДанныеГрафика)
	
	Серия = Диаграмма.Серии.Добавить("Количество");
	Серия.Текст = "Количество записей";
	
	Для Каждого СтрокаГрафика Из ДанныеГрафика Цикл
		Точка = Диаграмма.Точки.Добавить(СтрокаГрафика.Порядок);
		Точка.Текст = СтрокаГрафика.Интервал;
		Диаграмма.УстановитьЗначение(Точка, Серия, СтрокаГрафика.Количество);
	КонецЦикла;
	
	Диаграмма.Обновление = Истина;
	
КонецПроцедуры
