
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если МаксимумГрупп = 0 Тогда
		МаксимумГрупп = 25;
	КонецЕсли;
	
	Если МаксимумДеталейНаМесто = 0 Тогда
		МаксимумДеталейНаМесто = 20;
	КонецЕсли;
	
	Статус = "Выберите папку техжурнала и нажмите Сформировать.";
	
КонецПроцедуры

&НаКлиенте
Процедура ПутьККаталогуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если ОткрытьДиалогВыбораКаталога() Тогда
		Статус = "Папка выбрана. Нажмите Сформировать.";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиФормированияПриИзменении(Элемент)
	
	ОбновитьПредставлениеИзКэша();
	
КонецПроцедуры

&НаКлиенте
Функция ОткрытьДиалогВыбораКаталога()
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Выберите общую папку техжурнала";
	
	Если ЗначениеЗаполнено(ПутьККаталогу) Тогда
		Диалог.Каталог = ПутьККаталогу;
	КонецЕсли;
	
	Если Диалог.Выбрать() Тогда
		ПутьККаталогу = Диалог.Каталог;
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура Сформировать(Команда)
	
	ВремяНачала = ТекущаяДата();
	
	ПрочитатьФайлыИОбновитьПредставление(Истина);
	
	ВремяОкончания = ТекущаяДата();
	СекундВыполнения = ВремяОкончания - ВремяНачала;
	ВремяВыполнения = Дата(1,1,1) + СекундВыполнения;
	
	Статус = Статус + " (Прочитано за: " + Формат(ВремяВыполнения,"ДЛФ=T; ДП=0:00:00") + ")";
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьГрафик(Команда)
	
	АдресДанныхГрафика = ПолучитьАдресДанныхГрафикаНаСервере();
	Если ПустаяСтрока(АдресДанныхГрафика) Тогда
		Сообщить("Сначала сформируйте данные техжурнала.");
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("АдресДанныхГрафика", АдресДанныхГрафика);
	ОткрытьФорму("ВнешняяОбработка.АнализТехЖурналаДлительныеВызовы.Форма.ФормаГрафик", ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрочитатьФайлыИОбновитьПредставление(ПоказыватьСообщение = Ложь)
	
	Если ПустаяСтрока(ПутьККаталогу) Тогда
		Если ПоказыватьСообщение Тогда
			Сообщить("Не выбрана папка техжурнала.");
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Статус = "Идет чтение файлов техжурнала...";
	ТекстЗапроса = "";
	ТекстСтека = "";
	
	ПрочитатьФайлыТехЖурналаНаСервере();
	ОбновитьДеталиВыбранногоИтога();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредставлениеИзКэша()
	
	Если ВсеЗаписи.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса = "";
	ТекстСтека = "";
	ОбновитьПредставлениеИзКэшаНаСервере();
	ОбновитьДеталиВыбранногоИтога();
	
КонецПроцедуры

&НаКлиенте
Процедура ИтогиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОбновитьДеталиВыбранногоИтога();
	
КонецПроцедуры

&НаКлиенте
Процедура ИтогиПриАктивизацииСтроки(Элемент)
	
	ОбновитьДеталиВыбранногоИтога();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеталиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ОбновитьТекстВыбраннойДетали();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеталиПриАктивизацииСтроки(Элемент)
	
	ОбновитьТекстВыбраннойДетали();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеталиВыбранногоИтога()
	
	Детали.Очистить();
	ТекстЗапроса = "";
	ТекстСтека = "";
	
	ТекущиеДанные = Элементы.Итоги.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КлючГруппы = ТекущиеДанные.КлючГруппы;
	Для Каждого СтрокаДеталей Из ВсеДетали Цикл
		Если СтрокаДеталей.КлючГруппы = КлючГруппы Тогда
			НоваяСтрока = Детали.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДеталей);
		КонецЕсли;
	КонецЦикла;
	
	Если Детали.Количество() > 0 Тогда
		ОбновитьТекстВыбраннойДетали();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьТекстВыбраннойДетали()
	
	ТекущиеДанные = Элементы.Детали.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ТекстЗапроса = "";
		ТекстСтека = "";
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса = ТекущиеДанные.Запрос;
	
	Источник = "Файл: " + ТекущиеДанные.Файл + ", строка: " + Формат(ТекущиеДанные.НомерСтроки, "ЧГ=0");
	Если ПустаяСтрока(ТекущиеДанные.Стек) Тогда
		ТекстСтека = Источник;
	Иначе
		ТекстСтека = Источник + Символы.ПС + Символы.ПС + ТекущиеДанные.Стек;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьАдресДанныхГрафикаНаСервере()
	
	ДанныеГрафика = СформироватьДанныеГрафикаИзКэша();
	Если ДанныеГрафика.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ПоместитьВоВременноеХранилище(ДанныеГрафика);
	
КонецФункции

&НаСервере
Функция СформироватьДанныеГрафикаИзКэша()
	
	Группы = Новый Соответствие;
	
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		
		Если Не ЗаписьПроходитОтбор(ЗаписьКэша) Тогда
			Продолжить;
		КонецЕсли;
		
		КлючСтроки = ДанныеИнтервала10Минут(ЗаписьКэша.Время);
		
		СтарКол = Группы[КлючСтроки];
		Если СтарКол = Неопределено Тогда
			Группы.Вставить(КлючСтроки, 1);
		Иначе 
			Группы[КлючСтроки] = СтарКол + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	ДанныеГрафика = Новый ТаблицаЗначений;
	ДанныеГрафика.Колонки.Добавить("Порядок");
	ДанныеГрафика.Колонки.Добавить("Интервал");
	ДанныеГрафика.Колонки.Добавить("Количество");
	
	Для Каждого ЭлементГруппы Из Группы Цикл
		
		КлючСтроки = ЭлементГруппы.Ключ;
		ГодСтрокой = Сред(КлючСтроки, 7, 4);
		МесяцСтрокой = Сред(КлючСтроки, 4, 2);
		ДеньСтрокой = Сред(КлючСтроки, 1, 2);
		ЧасСтрокой = Сред(КлючСтроки, 12, 2);
		МинутаНачалаСтрокой = Сред(КлючСтроки, 15, 2);
		ДатаСтрокой = Лев(КлючСтроки, 10);
		
		Интервал = ДатаСтрокой + " " + ЧасСтрокой + ":" + МинутаНачалаСтрокой;
		Порядок = ГодСтрокой + МесяцСтрокой + ДеньСтрокой + ЧасСтрокой + МинутаНачалаСтрокой;
		
		НоваяСтрока = ДанныеГрафика.Добавить();
		НоваяСтрока.Порядок = Порядок;
		НоваяСтрока.Интервал = Интервал;
		НоваяСтрока.Количество = ЭлементГруппы.Значение;
		
	КонецЦикла;
	
	ДанныеГрафика.Сортировать("Порядок");
	
	Возврат ДанныеГрафика;
	
КонецФункции

&НаСервере
Функция ДанныеИнтервала10Минут(ВремяСтрокой)
	
	Попытка
		
		// Периоды по 10 минут
		//Минута = Число(Сред(ВремяСтрокой, 15, 2));
		//МинутаНачала = Цел(Минута / 10) * 10;
		//МинутаНачалаСтрокой = Формат(МинутаНачала, "ЧЦ=2; ЧН=00; ЧВН=; ЧГ=0");
		//КлючСтроки = Лев(ВремяСтрокой, 13) + ":" + МинутаНачалаСтрокой;
		
		// Периоды по 60 минут
		КлючСтроки = Лев(ВремяСтрокой, 13) + ":00";
		
		Возврат КлючСтроки;
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

&НаСервере
Процедура ПрочитатьФайлыТехЖурналаНаСервере()
	
	ОчиститьИтоги();
	Детали.Очистить();
	ВсеДетали.Очистить();
	ВсеЗаписи.Очистить();
	НачалоПериода = Дата(1, 1, 1);
	КонецПериода = Дата(1, 1, 1);
	
	Каталог = Новый Файл(ПутьККаталогу);
	Если Не Каталог.Существует() Или Не Каталог.ЭтоКаталог() Тогда
		Статус = "Папка не найдена: " + ПутьККаталогу;
		Возврат;
	КонецЕсли;
	
	ФайлыЖурнала = НайтиФайлы(ПутьККаталогу, "*.log", Истина);
	Если ФайлыЖурнала.Количество() = 0 Тогда
		Статус = "В выбранной папке не найдены файлы *.log.";
		Возврат;
	КонецЕсли;
	
	ОшибкиЧтения = 0;
	ВсегоЗаписей = 0;
	
	Для Каждого ФайлЖурнала Из ФайлыЖурнала Цикл
		ПрочитатьФайлТехЖурнала(ФайлЖурнала.ПолноеИмя, ВсегоЗаписей, ОшибкиЧтения);
	КонецЦикла;
	
	ЗаполнитьСвязиЗаписейТехЖурнала();
	ЗаполнитьПериодПоПрочитаннымЗаписям();
	
	Статус = "Файлов: " + Формат(ФайлыЖурнала.Количество(), "ЧГ=0")
		+ ", записей: " + Формат(ВсегоЗаписей, "ЧГ=0")
		+ (?(ОшибкиЧтения = 0, "", ", ошибок чтения: " + Формат(ОшибкиЧтения, "ЧГ=0")));
	
	ОбновитьПредставлениеИзКэшаНаСервере();	
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПредставлениеИзКэшаНаСервере()
	
	ОчиститьИтоги();
	Детали.Очистить();
	ВсеДетали.Очистить();
	
	Если ВсеЗаписи.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ГруппыCALL = Новый Соответствие;
	ГруппыКорневые = Новый Соответствие;
	ГруппыSDBLПоРодителю = Новый Соответствие;
	КлючиCALLПоКлючуЗаписи = Новый Соответствие;
	ЗаписейПослеОтбора = 0;
	МинимальнаяДатаОтбора = Неопределено;
	МаксимальнаяДатаОтбора = Неопределено;
	ЕстьНачалоПериода = ЗначениеЗаполнено(НачалоПериода);
	ЕстьКонецПериода = ЗначениеЗаполнено(КонецПериода);
	МаркерОтобраннойЗаписи = "#ОТОБРАНА#";
	
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		
		ЗаписьКэша.КлючДеталей = "";
		
		Если (ЕстьНачалоПериода Или ЕстьКонецПериода) И Не ЗначениеЗаполнено(ЗаписьКэша.ДатаВремя) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЕстьНачалоПериода И ЗаписьКэша.ДатаВремя < НачалоПериода Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЕстьКонецПериода И ЗаписьКэша.ДатаВремя > КонецПериода Тогда
			Продолжить;
		КонецЕсли;
		
		Если ИсключатьHoldConnection И НРег(ЗаписьКэша.Func) = "holdconnection" Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписейПослеОтбора = ЗаписейПослеОтбора + 1;
		
		Если ЗначениеЗаполнено(ЗаписьКэша.ДатаВремя) Тогда
			Если МинимальнаяДатаОтбора = Неопределено Или ЗаписьКэша.ДатаВремя < МинимальнаяДатаОтбора Тогда
				МинимальнаяДатаОтбора = ЗаписьКэша.ДатаВремя;
			КонецЕсли;
			
			Если МаксимальнаяДатаОтбора = Неопределено Или ЗаписьКэша.ДатаВремя > МаксимальнаяДатаОтбора Тогда
				МаксимальнаяДатаОтбора = ЗаписьКэша.ДатаВремя;
			КонецЕсли;
		КонецЕсли;
		
		Если ЗаписьКэша.ИмяСобытия = "CALL" Тогда
			КлючГруппы = КлючГруппировкиЗаписи(ЗаписьКэша);
			Итог = ПолучитьИлиСоздатьИтог(ГруппыCALL, КлючГруппы, ЗаписьКэша);
			ДобавитьЗаписьВИтог(Итог, ЗаписьКэша);
			ЗаписьКэша.КлючДеталей = КлючГруппы;
			КлючиCALLПоКлючуЗаписи.Вставить(КлючЗаписиТЖ(ЗаписьКэша), КлючГруппы);
		Иначе
			ЗаписьКэша.КлючДеталей = МаркерОтобраннойЗаписи;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		
		Если ПустаяСтрока(ЗаписьКэша.КлючДеталей) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗаписьКэша.ИмяСобытия = "CALL" Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЗаписьКэша.ИмяСобытия = "SDBL" И Не ПустаяСтрока(ЗаписьКэша.КлючРодительскогоCALL) Тогда
			КлючРодителя = КлючиCALLПоКлючуЗаписи.Получить(ЗаписьКэша.КлючРодительскогоCALL);
			Если КлючРодителя <> Неопределено Тогда
				ГруппыSDBL = ГруппыSDBLПоРодителю.Получить(КлючРодителя);
				Если ГруппыSDBL = Неопределено Тогда
					ГруппыSDBL = Новый Соответствие;
					ГруппыSDBLПоРодителю.Вставить(КлючРодителя, ГруппыSDBL);
				КонецЕсли;
				
				КлючГруппы = КлючДочернейГруппировки(КлючРодителя, ЗаписьКэша);
				Итог = ПолучитьИлиСоздатьИтог(ГруппыSDBL, КлючГруппы, ЗаписьКэша, КлючРодителя);
				ДобавитьЗаписьВИтог(Итог, ЗаписьКэша);
				ЗаписьКэша.КлючДеталей = КлючГруппы;
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		КлючГруппы = КлючГруппировкиЗаписи(ЗаписьКэша);
		Итог = ПолучитьИлиСоздатьИтог(ГруппыКорневые, КлючГруппы, ЗаписьКэша);
		ДобавитьЗаписьВИтог(Итог, ЗаписьКэша);
		ЗаписьКэша.КлючДеталей = КлючГруппы;
		
	КонецЦикла;
	
	ПериодВМинутах = ПериодВМинутахПоГраницам(МинимальнаяДатаОтбора, МаксимальнаяДатаОтбора);
	ПоказанныеКлючи = ЗаполнитьИтогиДеревом(ГруппыCALL, ГруппыSDBLПоРодителю, ГруппыКорневые, ПериодВМинутах);
	
	ДеталиПоКлючам = Новый Соответствие;
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		
		Если ПустаяСтрока(ЗаписьКэша.КлючДеталей) Тогда
			Продолжить;
		КонецЕсли;
		
		КлючГруппы = ЗаписьКэша.КлючДеталей;
		Если ПустаяСтрока(КлючГруппы)
			Или КлючГруппы = МаркерОтобраннойЗаписи
			Или ПоказанныеКлючи.Получить(КлючГруппы) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Деталь = Новый Структура;
		Деталь.Вставить("КлючГруппы", КлючГруппы);
		Деталь.Вставить("ДлительностьМКС", ЗаписьКэша.ДлительностьМКС);
		Деталь.Вставить("ДлительностьСек", ЗаписьКэша.ДлительностьСек);
		Деталь.Вставить("CpuTime", Окр(ЗаписьКэша.CpuTime / 1000000, 3));
		Деталь.Вставить("Время", ЗаписьКэша.Время);
		Деталь.Вставить("Файл", ЗаписьКэша.Файл);
		Деталь.Вставить("НомерСтроки", ЗаписьКэша.НомерСтроки);
		Деталь.Вставить("Пользователь", ЗаписьКэша.Пользователь);
		Деталь.Вставить("Сеанс", ЗаписьКэша.Сеанс);
		Деталь.Вставить("Запрос", ЗаписьКэша.Запрос);
		Деталь.Вставить("Стек", ЗаписьКэша.Стек);
		
		ДобавитьДетальКГруппе(ДеталиПоКлючам, Деталь, МаксимумДеталейНаМесто);
		
	КонецЦикла;
	
	ЗаполнитьВсеДетали(ДеталиПоКлючам);
	Статус = "Прочитано записей: " + Формат(ВсеЗаписи.Количество(), "ЧГ=0")
		+ ", после отбора: " + Формат(ЗаписейПослеОтбора, "ЧГ=0")
		+ ", групп: " + Формат(ПоказанныеКлючи.Количество(), "ЧГ=0");
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьФайлТехЖурнала(ИмяФайла, ВсегоЗаписей, ОшибкиЧтения)
	
	Попытка
		Чтение = Новый ЧтениеТекста(ИмяФайла);
	Исключение
		ОшибкиЧтения = ОшибкиЧтения + 1;
		Возврат;
	КонецПопытки;
	
	СтрокиЗаписи = Новый Массив;
	НомерСтроки = 0;
	НомерСтрокиНачалаЗаписи = 0;
	ДатаФайлаТЖ = ПредставлениеДатыФайлаТЖ(ИмяФайла);
	
	Попытка
		Строка = Чтение.ПрочитатьСтроку();
		Пока Строка <> Неопределено Цикл
			
			НомерСтроки = НомерСтроки + 1;
			
			Если Сред(Строка, 3, 1) = ":" И Сред(Строка, 6, 1) = "." Тогда
				ИмяСобытияСтроки = ИмяСобытияНачалаЗаписиТехЖурнала(Строка);
			Иначе
				ИмяСобытияСтроки = "";
			КонецЕсли;
			
			Если Не ПустаяСтрока(ИмяСобытияСтроки) Тогда
				Если СтрокиЗаписи.Количество() > 0 Тогда
					ОбработатьЗаписьТехЖурнала(СоединитьСтрокиЗаписи(СтрокиЗаписи), ИмяФайла, ДатаФайлаТЖ, НомерСтрокиНачалаЗаписи, ВсегоЗаписей);
				КонецЕсли;
				СтрокиЗаписи = Новый Массив;
				
				Если ЭтоЦелевоеСобытие(ИмяСобытияСтроки) Тогда
					СтрокиЗаписи.Добавить(Строка);
					НомерСтрокиНачалаЗаписи = НомерСтроки;
				Иначе
					НомерСтрокиНачалаЗаписи = 0;
				КонецЕсли;
			ИначеЕсли НомерСтрокиНачалаЗаписи <> 0 Тогда
				СтрокиЗаписи.Добавить(Строка);
			КонецЕсли;
			
			Строка = Чтение.ПрочитатьСтроку();
			
		КонецЦикла;
		
		Если СтрокиЗаписи.Количество() > 0 Тогда
			ОбработатьЗаписьТехЖурнала(СоединитьСтрокиЗаписи(СтрокиЗаписи), ИмяФайла, ДатаФайлаТЖ, НомерСтрокиНачалаЗаписи, ВсегоЗаписей);
		КонецЕсли;
		
		Чтение.Закрыть();
		
	Исключение
		ОшибкиЧтения = ОшибкиЧтения + 1;
		Попытка
			Чтение.Закрыть();
		Исключение
		КонецПопытки;
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция СоединитьСтрокиЗаписи(СтрокиЗаписи)
	
	Если СтрокиЗаписи.Количество() = 1 Тогда
		Возврат СтрокиЗаписи[0];
	КонецЕсли;
	
	Возврат СтрСоединить(СтрокиЗаписи, Символы.ПС);
	
КонецФункции

&НаСервере
Процедура ОбработатьЗаписьТехЖурнала(Запись, ИмяФайла, ДатаФайлаТЖ, НомерСтроки, ВсегоЗаписей)
	
	ЗаголовокТЖ = РазобратьЗаголовокЗаписи(Запись);
	//Если ЗаголовокТЖ = Неопределено Тогда
	//	Возврат;
	//КонецЕсли;
	//
	//Если Не ЭтоЦелевоеСобытие(ЗаголовокТЖ.ИмяСобытия) Тогда
	//	Возврат;
	//КонецЕсли;
	
	ВсегоЗаписей = ВсегоЗаписей + 1;
	
	Поля = ИзвлечьНужныеПоляЗаписи(Запись, ЗаголовокТЖ.ИмяСобытия, ЗаголовокТЖ.ПозицияНачалаПолей);
	
	Контекст = ЗначениеПоля(Поля, "Context");
	МестоВызова = ЗначениеПоля(Поля, "МестоВызоваКонтекста");
	Если ПустаяСтрока(МестоВызова) Тогда
		МестоВызова = ОпределитьМестоВызова(ЗаголовокТЖ.ИмяСобытия, Поля);
	КонецЕсли;
	ПерваяСтрокаКонтекста = ЗначениеПоля(Поля, "ПерваяСтрокаКонтекста");
	ДатаВремяЗаписи = ДатаВремяЗаписиТЖ(ДатаФайлаТЖ, ЗаголовокТЖ.Время);
	МоментОкончанияМКС = МоментОкончанияЗаписиТЖМКС(ДатаВремяЗаписи, ЗаголовокТЖ.Время);
	
	НоваяЗапись = ВсеЗаписи.Добавить();
	НоваяЗапись.ИмяСобытия = ЗаголовокТЖ.ИмяСобытия;
	НоваяЗапись.МестоВызова = Лев(МестоВызова, 1000);
	НоваяЗапись.ДлительностьМКС = ЗаголовокТЖ.ДлительностьМКС;
	НоваяЗапись.ДлительностьСек = Окр(ЗаголовокТЖ.ДлительностьМКС / 1000000, 3);
	НоваяЗапись.CpuTime = ЧислоПоля(ЗначениеПоля(Поля, "CpuTime"));
	НоваяЗапись.Время = ДатаФайлаТЖ + ЗаголовокТЖ.Время;
	НоваяЗапись.ДатаВремя = ДатаВремяЗаписи;
	НоваяЗапись.МоментОкончанияМКС = МоментОкончанияМКС;
	НоваяЗапись.МоментНачалаМКС = ?(МоментОкончанияМКС = 0, 0, МоментОкончанияМКС - ЗаголовокТЖ.ДлительностьМКС);
	НоваяЗапись.Файл = ИмяФайла;
	НоваяЗапись.НомерСтроки = НомерСтроки;
	НоваяЗапись.Пользователь = ЗначениеПоля(Поля, "Usr");
	НоваяЗапись.Сеанс = ЗначениеПоля(Поля, "SessionID");
	НоваяЗапись.Func = ЗначениеПоля(Поля, "Func");
	НоваяЗапись.Запрос = ОпределитьЗапрос(ЗаголовокТЖ.ИмяСобытия, Поля);
	НоваяЗапись.Стек = Контекст;
	НоваяЗапись.ПерваяСтрокаКонтекста = Лев(ПерваяСтрокаКонтекста, 1000);
	НоваяЗапись.КлючРодительскогоCALL = "";
	НоваяЗапись.КлючДеталей = "";
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвязиЗаписейТехЖурнала()
	
	ИндексCALL = Новый Соответствие;
	ИндексДлинныхCALL = Новый Соответствие;
	ИндексНеполныхCALL = Новый Соответствие;
	ИндексДлинныхНеполныхCALL = Новый Соответствие;
	
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		
		ЗаписьКэша.КлючРодительскогоCALL = "";
		ЗаписьКэша.КлючДеталей = "";
		
		Если ЗаписьКэша.ИмяСобытия = "CALL" Тогда
			ДобавитьCALLВИндекс(ИндексCALL, ИндексДлинныхCALL, ИндексНеполныхCALL, ИндексДлинныхНеполныхCALL, ЗаписьКэша);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		
		Если ЗаписьКэша.ИмяСобытия <> "SDBL" Тогда
			Продолжить;
		КонецЕсли;
		
		РодительскийCALL = НайтиРодительскийCALL(ЗаписьКэша, ИндексCALL, ИндексДлинныхCALL, ИндексНеполныхCALL, ИндексДлинныхНеполныхCALL);
		Если РодительскийCALL <> Неопределено Тогда
			ЗаписьКэша.КлючРодительскогоCALL = КлючЗаписиТЖ(РодительскийCALL);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ЗаписьПроходитОтбор(ЗаписьКэша)
	
	Если Не ЗаписьПроходитОтборПериода(ЗаписьКэша) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИсключатьHoldConnection И НРег(ЗаписьКэша.Func) = "holdconnection" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ЗаписьПроходитОтборПериода(ЗаписьКэша)
	
	ЕстьНачалоПериода = ЗначениеЗаполнено(НачалоПериода);
	ЕстьКонецПериода = ЗначениеЗаполнено(КонецПериода);
	Если Не ЕстьНачалоПериода И Не ЕстьКонецПериода Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЗаписьКэша.ДатаВремя) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЕстьНачалоПериода И ЗаписьКэша.ДатаВремя < НачалоПериода Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЕстьКонецПериода И ЗаписьКэша.ДатаВремя > КонецПериода Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПериодПоПрочитаннымЗаписям()
	
	МинимальнаяДата = Неопределено;
	МаксимальнаяДата = Неопределено;
	
	Для Каждого ЗаписьКэша Из ВсеЗаписи Цикл
		Если Не ЗначениеЗаполнено(ЗаписьКэша.ДатаВремя) Тогда
			Продолжить;
		КонецЕсли;
		
		Если МинимальнаяДата = Неопределено Или ЗаписьКэша.ДатаВремя < МинимальнаяДата Тогда
			МинимальнаяДата = ЗаписьКэша.ДатаВремя;
		КонецЕсли;
		
		Если МаксимальнаяДата = Неопределено Или ЗаписьКэша.ДатаВремя > МаксимальнаяДата Тогда
			МаксимальнаяДата = ЗаписьКэша.ДатаВремя;
		КонецЕсли;
	КонецЦикла;
	
	Если МинимальнаяДата = Неопределено Тогда
		НачалоПериода = Дата(1, 1, 1);
		КонецПериода = Дата(1, 1, 1);
	Иначе
		НачалоПериода = МинимальнаяДата;
		КонецПериода = МаксимальнаяДата;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПериодВМинутахПоГраницам(МинимальнаяДата, МаксимальнаяДата)
	
	Если МинимальнаяДата = Неопределено Тогда
		Возврат 1;
	КонецЕсли;
	
	ПериодВМинутах = (МаксимальнаяДата - МинимальнаяДата) / 60;
	Если ПериодВМинутах < 1 Тогда
		Возврат 1;
	КонецЕсли;
	
	Возврат ПериодВМинутах;
	
КонецФункции

&НаСервере
Процедура ОчиститьИтоги()
	
	Итоги.ПолучитьЭлементы().Очистить();
	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьИтогиДеревом(ГруппыCALL, ГруппыSDBLПоРодителю, ГруппыКорневые, ПериодВМинутах)
	
	ПоказанныеКлючи = Новый Соответствие;
	КоличествоCALL = 0;
	
	Для Каждого ИтогCALL Из ОтсортированныеИтоги(ГруппыCALL) Цикл
		
		Если МаксимумГрупп > 0 И КоличествоCALL >= МаксимумГрупп Тогда
			Прервать;
		КонецЕсли;
		
		СтрокаCALL = Итоги.ПолучитьЭлементы().Добавить();
		ЗаполнитьСтрокуИтога(СтрокаCALL, ИтогCALL, ПериодВМинутах);
		ПоказанныеКлючи.Вставить(ИтогCALL.КлючГруппы, Истина);
		КоличествоCALL = КоличествоCALL + 1;
		
		ГруппыSDBL = ГруппыSDBLПоРодителю.Получить(ИтогCALL.КлючГруппы);
		Если ГруппыSDBL <> Неопределено Тогда
			Для Каждого ИтогSDBL Из ОтсортированныеИтоги(ГруппыSDBL) Цикл
				СтрокаSDBL = СтрокаCALL.ПолучитьЭлементы().Добавить();
				ЗаполнитьСтрокуИтога(СтрокаSDBL, ИтогSDBL, ПериодВМинутах);
				ПоказанныеКлючи.Вставить(ИтогSDBL.КлючГруппы, Истина);
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ИтогКорня Из ОтсортированныеИтоги(ГруппыКорневые) Цикл
		СтрокаКорня = Итоги.ПолучитьЭлементы().Добавить();
		ЗаполнитьСтрокуИтога(СтрокаКорня, ИтогКорня, ПериодВМинутах);
		ПоказанныеКлючи.Вставить(ИтогКорня.КлючГруппы, Истина);
	КонецЦикла;
	
	Возврат ПоказанныеКлючи;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСтрокуИтога(СтрокаИтога, Итог, ПериодВМинутах)
	
	СтрокаИтога.КлючГруппы = Итог.КлючГруппы;
	СтрокаИтога.ТипСтроки = Итог.ТипСтроки;
	СтрокаИтога.КлючРодителя = Итог.КлючРодителя;
	СтрокаИтога.ИмяСобытия = Итог.ИмяСобытия;
	СтрокаИтога.МестоВызова = Итог.МестоВызова;
	СтрокаИтога.Количество = Итог.Количество;
	СтрокаИтога.КоличествоЗапросовВМинуту = Окр(Итог.Количество / ПериодВМинутах, 3);
	СтрокаИтога.СуммарноСек = Окр(Итог.СуммарноМКС / 1000000, 3);
	СтрокаИтога.СреднеСек = ?(Итог.Количество = 0, 0, Окр(Итог.СуммарноМКС / Итог.Количество / 1000000, 3));
	СтрокаИтога.МаксимумСек = Окр(Итог.МаксимумМКС / 1000000, 3);
	СтрокаИтога.СуммарноCPU = Окр(Итог.СуммарноCPU / 1000000, 3);
	СтрокаИтога.СреднеCPU = ?(Итог.Количество = 0, 0, Окр(Итог.СуммарноCPU / Итог.Количество / 1000000, 3));
	СтрокаИтога.МаксимумCPU = Окр(Итог.МаксимумCPU / 1000000, 3);
	СтрокаИтога.Пользователь = Итог.Пользователь;
	СтрокаИтога.Сеанс = Итог.Сеанс;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьИлиСоздатьИтог(Группы, КлючГруппы, ЗаписьКэша, КлючРодителя = "")
	
	Итог = Группы.Получить(КлючГруппы);
	Если Итог <> Неопределено Тогда
		Возврат Итог;
	КонецЕсли;
	
	Итог = Новый Структура;
	Итог.Вставить("КлючГруппы", КлючГруппы);
	Итог.Вставить("КлючРодителя", КлючРодителя);
	Итог.Вставить("ТипСтроки", ЗаписьКэша.ИмяСобытия);
	Итог.Вставить("ИмяСобытия", ЗаписьКэша.ИмяСобытия);
	Итог.Вставить("МестоВызова", ЗаписьКэша.МестоВызова);
	Итог.Вставить("Пользователь", ?(УчитыватьПользователейИСеансы, ЗаписьКэша.Пользователь, ""));
	Итог.Вставить("Сеанс", ?(УчитыватьПользователейИСеансы, ЗаписьКэша.Сеанс, ""));
	Итог.Вставить("Количество", 0);
	Итог.Вставить("СуммарноМКС", 0);
	Итог.Вставить("МаксимумМКС", 0);
	Итог.Вставить("СуммарноCPU", 0);
	Итог.Вставить("МаксимумCPU", 0);
	Группы.Вставить(КлючГруппы, Итог);
	
	Возврат Итог;
	
КонецФункции

&НаСервере
Процедура ДобавитьЗаписьВИтог(Итог, ЗаписьКэша)
	
	Итог.Количество = Итог.Количество + 1;
	Итог.СуммарноМКС = Итог.СуммарноМКС + ЗаписьКэша.ДлительностьМКС;
	Если ЗаписьКэша.ДлительностьМКС > Итог.МаксимумМКС Тогда
		Итог.МаксимумМКС = ЗаписьКэша.ДлительностьМКС;
	КонецЕсли;
	
	Итог.СуммарноCPU = Итог.СуммарноCPU + ЗаписьКэша.CpuTime;
	Если ЗаписьКэша.CpuTime > Итог.МаксимумCPU Тогда
		Итог.МаксимумCPU = ЗаписьКэша.CpuTime;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОтсортированныеИтоги(Группы)
	
	ТаблицаИтогов = Новый ТаблицаЗначений;
	ТаблицаИтогов.Колонки.Добавить("СуммарноМКС");
	ТаблицаИтогов.Колонки.Добавить("Итог");
	
	Для Каждого ЭлементГруппы Из Группы Цикл
		СтрокаИтогов = ТаблицаИтогов.Добавить();
		СтрокаИтогов.СуммарноМКС = ЭлементГруппы.Значение.СуммарноМКС;
		СтрокаИтогов.Итог = ЭлементГруппы.Значение;
	КонецЦикла;
	
	ТаблицаИтогов.Сортировать("СуммарноМКС Убыв");
	
	Результат = Новый Массив;
	Для Каждого СтрокаИтогов Из ТаблицаИтогов Цикл
		Результат.Добавить(СтрокаИтогов.Итог);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ДобавитьCALLВИндекс(ИндексCALL, ИндексДлинныхCALL, ИндексНеполныхCALL, ИндексДлинныхНеполныхCALL, ЗаписьCALL)
	
	ДобавитьCALLВИндексПоИнтервалу(
		ИндексCALL,
		ИндексДлинныхCALL,
		КлючИндексаCALL(ЗаписьCALL.МестоВызова, ЗаписьCALL.Пользователь, ЗаписьCALL.Сеанс),
		ЗаписьCALL);
	
	Если ПустаяСтрока(ЗаписьCALL.Пользователь) Или ПустаяСтрока(ЗаписьCALL.Сеанс) Тогда
		ДобавитьCALLВИндексПоИнтервалу(
			ИндексНеполныхCALL,
			ИндексДлинныхНеполныхCALL,
			СокрЛП(ЗаписьCALL.МестоВызова),
			ЗаписьCALL);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьCALLВИндексПоИнтервалу(ИндексCALL, ИндексДлинныхCALL, БазовыйКлюч, ЗаписьCALL)
	
	Если ЗаписьCALL.МоментНачалаМКС = 0 Или ЗаписьCALL.МоментОкончанияМКС = 0 Тогда
		ДобавитьCALLВИндексПоКлючу(ИндексДлинныхCALL, БазовыйКлюч, ЗаписьCALL);
		Возврат;
	КонецЕсли;
	
	СекундаНачала = СекундаМоментаМКС(ЗаписьCALL.МоментНачалаМКС);
	СекундаОкончания = СекундаМоментаМКС(ЗаписьCALL.МоментОкончанияМКС);
	
	Если СекундаОкончания < СекундаНачала Или СекундаОкончания - СекундаНачала > 60 Тогда
		ДобавитьCALLВИндексПоКлючу(ИндексДлинныхCALL, БазовыйКлюч, ЗаписьCALL);
		Возврат;
	КонецЕсли;
	
	Для Секунда = СекундаНачала По СекундаОкончания Цикл
		ДобавитьCALLВИндексПоКлючу(ИндексCALL, КлючСекундногоИндексаCALL(БазовыйКлюч, Секунда), ЗаписьCALL);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьCALLВИндексПоКлючу(ИндексCALL, КлючИндекса, ЗаписьCALL)
	
	Кандидаты = ИндексCALL.Получить(КлючИндекса);
	Если Кандидаты = Неопределено Тогда
		Кандидаты = Новый Массив;
		ИндексCALL.Вставить(КлючИндекса, Кандидаты);
	КонецЕсли;
	
	Кандидаты.Добавить(ЗаписьCALL);
	
КонецПроцедуры

&НаСервере
Функция КлючИндексаCALL(МестоВызова, Пользователь, Сеанс)
	
	Возврат СокрЛП(МестоВызова)
		+ "|USR=" + СокрЛП(Пользователь)
		+ "|SESSION=" + СокрЛП(Сеанс);
	
КонецФункции

