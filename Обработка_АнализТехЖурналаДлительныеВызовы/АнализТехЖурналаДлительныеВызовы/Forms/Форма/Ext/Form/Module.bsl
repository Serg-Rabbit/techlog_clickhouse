&НаСервере
Функция СтрокаСостоитИзЦифр(Строка)
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Позиция = 1 По СтрДлина(Строка) Цикл
		Если СтрНайти("0123456789", Сред(Строка, Позиция, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ПерваяСтрокаТекста(Текст)
	
	Текст = СтрЗаменить(Текст, Символы.ВК, Символы.ПС);
	Строки = СтрРазделить(Текст, Символы.ПС, Ложь);
	Если Строки.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Для Индекс = 0 По Строки.Количество() - 1 Цикл
		Строка = СокрЛП(Строки[Индекс]);
		Если Не ПустаяСтрока(Строка) Тогда
			Возврат Строка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ПоследняяСтрокаТекста(Текст)
	
	Текст = СтрЗаменить(Текст, Символы.ВК, Символы.ПС);
	Строки = СтрРазделить(Текст, Символы.ПС, Ложь);
	Если Строки.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Индекс = Строки.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Строка = СокрЛП(Строки[Индекс]);
		Если Не ПустаяСтрока(Строка) Тогда
			Возврат Строка;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ПредставлениеДатыФайлаТЖ(ИмяФайла)
	
	ФайлТЖ = Новый Файл(ИмяФайла);
	ИмяБезРасширения = ФайлТЖ.ИмяБезРасширения;
	Если СтрДлина(ИмяБезРасширения) < 8 Или Не СтрокаСостоитИзЦифр(Лев(ИмяБезРасширения, 8)) Тогда
		Возврат "";
	КонецЕсли;
	
	Год = 2000 + Число(Лев(ИмяБезРасширения, 2));
	Месяц = Число(Сред(ИмяБезРасширения, 3, 2));
	День = Число(Сред(ИмяБезРасширения, 5, 2));
	Час = Число(Сред(ИмяБезРасширения, 7, 2));
	ЧасСтрокой = Формат(Час, "ЧГ=0");
	Если Час < 10 Тогда
		ЧасСтрокой = "0" + ЧасСтрокой;
	КонецЕсли;
	
	Возврат Формат(Дата(Год, Месяц, День), "ДФ=dd.MM.yyyy")
		+ " " + ЧасСтрокой + ":";
	
КонецФункции

&НаСервере
Функция МоментОкончанияЗаписиТЖМКС(ДатаВремяЗаписи, ВремяВЗаписи)
	
	Если ДатаВремяЗаписи = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Микросекунда = МикросекундаВремениЗаписиТЖ(ВремяВЗаписи);
	Возврат (ДатаВремяЗаписи - Дата(1, 1, 1)) * 1000000 + Микросекунда;
	
КонецФункции

&НаСервере
Функция МикросекундаВремениЗаписиТЖ(ВремяВЗаписи)
	
	ПозицияТочки = СтрНайти(ВремяВЗаписи, ".");
	Если ПозицияТочки = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	ДробнаяЧасть = Сред(ВремяВЗаписи, ПозицияТочки + 1, 6);
	Если ПустаяСтрока(ДробнаяЧасть) Тогда
		Возврат 0;
	КонецЕсли;
	
	Пока СтрДлина(ДробнаяЧасть) < 6 Цикл
		ДробнаяЧасть = ДробнаяЧасть + "0";
	КонецЦикла;
	
	Попытка
		Возврат Число(ДробнаяЧасть);
	Исключение
		Возврат 0;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ДатаВремяЗаписиТЖ(ДатаФайлаТЖ, ВремяВЗаписи)
	
	Попытка
		Если ПустаяСтрока(ДатаФайлаТЖ) Или СтрДлина(ВремяВЗаписи) < 5 Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		День = Число(Сред(ДатаФайлаТЖ, 1, 2));
		Месяц = Число(Сред(ДатаФайлаТЖ, 4, 2));
		Год = Число(Сред(ДатаФайлаТЖ, 7, 4));
		Час = Число(Сред(ДатаФайлаТЖ, 12, 2));
		Минута = Число(Сред(ВремяВЗаписи, 1, 2));
		Секунда = Число(Сред(ВремяВЗаписи, 4, 2));
		
		Возврат Дата(Год, Месяц, День, Час, Минута, Секунда);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ПутьККаталогуОткрытиеНаСервере()
	Результаты = Новый Структура("Ошибки, Файлов, Строк, Размер","", 0, 0, 0);	
	Каталог = Новый Файл(ПутьККаталогу);
	Если Не Каталог.Существует() Или Не Каталог.ЭтоКаталог() Тогда
		Результаты.Ошибки = "Папка не найдена: " + ПутьККаталогу;
		Возврат Результаты;
	КонецЕсли;
	
	ФайлыЖурнала = НайтиФайлы(ПутьККаталогу, "*.log", Истина);
	Если ФайлыЖурнала.Количество() = 0 Тогда
		Результаты.Ошибки = "В выбранной папке не найдены файлы *.log.";
		Возврат Результаты;
	КонецЕсли;
	Результаты.Файлов = ФайлыЖурнала.Количество();
	Для Каждого ФайлЖурнала Из ФайлыЖурнала Цикл
		ТД = Новый ТекстовыйДокумент;
		ТД.Прочитать(ФайлЖурнала.ПолноеИмя);
		Результаты.Строк = Результаты.Строк + ТД.КоличествоСтрок();
		Результаты.Размер = Результаты.Размер + ФайлЖурнала.Размер();
	КонецЦикла;

	//Чтение текста дольше в несколько раз
	//Для Каждого ФайлЖурнала Из ФайлыЖурнала Цикл
	//	Чтение = Новый ЧтениеТекста(ФайлЖурнала.ПолноеИмя);
	//	Строка = Чтение.ПрочитатьСтроку();
	//	Пока Строка <> Неопределено Цикл
	//		Строка = Чтение.ПрочитатьСтроку();
	//		Результаты.Строк = Результаты.Строк + 1;
	//	КонецЦикла;
	//	Чтение.Закрыть();
	//КонецЦикла;
	
	Возврат Результаты;
КонецФункции

&НаКлиенте
Процедура ПутьККаталогуОткрытие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Результаты = ПутьККаталогуОткрытиеНаСервере();
	Если ЗначениеЗаполнено(Результаты.Ошибки) Тогда
		ПоказатьПредупреждение(,Результаты.Ошибки);
	Иначе
		ПоказатьПредупреждение(,"Файлов " + Результаты.Файлов + Символы.ПС 
		+ "Строк " + Результаты.Строк + Символы.ПС
		+ "Размер(мб) " + Окр(Результаты.Размер / (1024*1024),1));
	КонецЕсли;
	
КонецПроцедуры
