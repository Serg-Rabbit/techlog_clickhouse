	Возврат Цел(МоментМКС / 1000000);
	
КонецФункции

&НаСервере
Функция НайтиРодительскийCALL(ЗаписьSDBL, ИндексCALL, ИндексДлинныхCALL, ИндексНеполныхCALL, ИндексДлинныхНеполныхCALL)
	
	ПерваяСтрокаКонтекста = СокрЛП(ЗаписьSDBL.ПерваяСтрокаКонтекста);
	Если ПустаяСтрока(ПерваяСтрокаКонтекста) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПользовательSDBL = ЗаписьSDBL.Пользователь;
	СеансSDBL = ЗаписьSDBL.Сеанс;
	НачалоSDBL = ЗаписьSDBL.МоментНачалаМКС;
	ОкончаниеSDBL = ЗаписьSDBL.МоментОкончанияМКС;
	СекундаSDBL = СекундаМоментаМКС(ОкончаниеSDBL);
	
	ТочныйКлюч = КлючИндексаCALL(ПерваяСтрокаКонтекста, ПользовательSDBL, СеансSDBL);
	Кандидаты = ИндексCALL.Получить(КлючСекундногоИндексаCALL(ТочныйКлюч, СекундаSDBL));
	Если Кандидаты <> Неопределено Тогда
		ЛучшийCALL = НайтиЛучшийCALLСКандидатах(Кандидаты, ПользовательSDBL, СеансSDBL, НачалоSDBL, ОкончаниеSDBL);
		Если ЛучшийCALL <> Неопределено Тогда
			Возврат ЛучшийCALL;
		КонецЕсли;
	КонецЕсли;
	
	Кандидаты = ИндексДлинныхCALL.Получить(ТочныйКлюч);
	Если Кандидаты <> Неопределено Тогда
		ЛучшийCALL = НайтиЛучшийCALLСКандидатах(Кандидаты, ПользовательSDBL, СеансSDBL, НачалоSDBL, ОкончаниеSDBL);
		Если ЛучшийCALL <> Неопределено Тогда
			Возврат ЛучшийCALL;
		КонецЕсли;
	КонецЕсли;
	
	Кандидаты = ИндексНеполныхCALL.Получить(КлючСекундногоИндексаCALL(ПерваяСтрокаКонтекста, СекундаSDBL));
	Если Кандидаты <> Неопределено Тогда
		ЛучшийCALL = НайтиЛучшийCALLСКандидатах(Кандидаты, ПользовательSDBL, СеансSDBL, НачалоSDBL, ОкончаниеSDBL);
		Если ЛучшийCALL <> Неопределено Тогда
			Возврат ЛучшийCALL;
		КонецЕсли;
	КонецЕсли;
	
	Кандидаты = ИндексДлинныхНеполныхCALL.Получить(ПерваяСтрокаКонтекста);
	Если Кандидаты <> Неопределено Тогда
		Возврат НайтиЛучшийCALLСКандидатах(Кандидаты, ПользовательSDBL, СеансSDBL, НачалоSDBL, ОкончаниеSDBL);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция НайтиЛучшийCALLСКандидатах(Кандидаты, ПользовательSDBL, СеансSDBL, НачалоSDBL, ОкончаниеSDBL)
	
	ЛучшийCALL = Неопределено;
	ЛучшаяДлительность = 0;
	
	Для Каждого ЗаписьCALL Из Кандидаты Цикл
		
		Если Не ПустаяСтрока(ПользовательSDBL) И Не ПустаяСтрока(ЗаписьCALL.Пользователь) И ПользовательSDBL <> ЗаписьCALL.Пользователь Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ПустаяСтрока(СеансSDBL) И Не ПустаяСтрока(ЗаписьCALL.Сеанс) И СеансSDBL <> ЗаписьCALL.Сеанс Тогда
			Продолжить;
		КонецЕсли;
		
		Если НачалоSDBL = 0
			Или ОкончаниеSDBL = 0
			Или ЗаписьCALL.МоментНачалаМКС = 0
			Или ЗаписьCALL.МоментОкончанияМКС = 0
			Или НачалоSDBL < ЗаписьCALL.МоментНачалаМКС
			Или ОкончаниеSDBL > ЗаписьCALL.МоментОкончанияМКС Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЛучшийCALL = Неопределено Или ЗаписьCALL.ДлительностьМКС < ЛучшаяДлительность Тогда
			ЛучшийCALL = ЗаписьCALL;
			ЛучшаяДлительность = ЗаписьCALL.ДлительностьМКС;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ЛучшийCALL;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьВсеДетали(ДеталиПоКлючам)
	
	Для Каждого ЭлементДеталей Из ДеталиПоКлючам Цикл
		Для Каждого Деталь Из ЭлементДеталей.Значение.Детали Цикл
			НоваяСтрока = ВсеДетали.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Деталь);
		КонецЦикла;
	КонецЦикла;
	
	ВсеДетали.Сортировать("КлючГруппы, ДлительностьСек Убыв");
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьДетальКГруппе(ДеталиПоКлючам, Деталь, МаксимумДеталей)
	
	Если МаксимумДеталей <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	МассивДеталей = ДеталиПоКлючам.Получить(Деталь.КлючГруппы);
	Если МассивДеталей = Неопределено Тогда
		МассивДеталей = Новый Структура;
		МассивДеталей.Вставить("Детали", Новый Массив);
		ДеталиПоКлючам.Вставить(Деталь.КлючГруппы, МассивДеталей);
	КонецЕсли;
	
	ДеталиГруппы = МассивДеталей.Детали;
	
	Если ДеталиГруппы.Количество() < МаксимумДеталей Тогда
		ВставитьДетальПоДлительности(ДеталиГруппы, Деталь);
		Возврат;
	КонецЕсли;
	
	ИндексПоследней = ДеталиГруппы.Количество() - 1;
	Если Деталь.ДлительностьМКС <= ДеталиГруппы[ИндексПоследней].ДлительностьМКС Тогда
		Возврат;
	КонецЕсли;
	
	ДеталиГруппы.Удалить(ИндексПоследней);
	ВставитьДетальПоДлительности(ДеталиГруппы, Деталь);
	
КонецПроцедуры

&НаСервере
Процедура ВставитьДетальПоДлительности(ДеталиГруппы, Деталь)
	
	Если ДеталиГруппы.Количество() = 0 Тогда
		ДеталиГруппы.Добавить(Деталь);
		Возврат;
	КонецЕсли;
	
	Для Индекс = 0 По ДеталиГруппы.Количество() - 1 Цикл
		Если Деталь.ДлительностьМКС > ДеталиГруппы[Индекс].ДлительностьМКС Тогда
			ДеталиГруппы.Вставить(Индекс, Деталь);
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	ДеталиГруппы.Добавить(Деталь);
	
КонецПроцедуры

