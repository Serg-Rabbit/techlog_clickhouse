&НаСервере
Функция ИзвлечьНужныеПоляЗаписи(Запись, ИмяСобытия, ПозицияНачала)
	
	Поля = Новый Соответствие;
	
	ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Usr");
	ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "SessionID");
	ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Context");
	ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "CpuTime");
	ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Func");
	
	КонтекстНеЗаполнен = Не ЗначениеЗаполнено(Поля.Получить("Context"));
	
	Если ИмяСобытия = "CALL" Тогда
		Если КонтекстНеЗаполнен Тогда
			ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "IName");
			ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "MName");
			ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Module");
			ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Method");
			ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Report");
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "SDBL" Тогда
		ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Sdbl");
		Если КонтекстНеЗаполнен Тогда
			ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "tableName");
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "DBMSSQL" Тогда
		ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Sql");
	ИначеЕсли ИмяСобытия = "TLOCK" Тогда
		ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Locks");
		ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, "Regions");
	КонецЕсли;
	
	Возврат Поля;
	
КонецФункции

&НаСервере
Процедура ДобавитьПолеЕслиЕсть(Поля, Запись, ПозицияНачала, ИмяПоля)
	
	ПозицияЗначения = ПозицияЗначенияПоляЗаписи(Запись, ПозицияНачала, ИмяПоля);
	Если ПозицияЗначения = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Значение = ПрочитатьЗначениеПоляРазбора(Запись, ПозицияЗначения);
	Поля.Вставить(ИмяПоля, Значение);
	
	Если ИмяПоля = "Context" Тогда
		ЗаполнитьСтрокиКонтекста(Поля, Значение);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПозицияЗначенияПоляЗаписи(Запись, ПозицияНачала, ИмяПоля)
	
	ШаблонПервогоПоля = ИмяПоля + "=";
	ДлинаШаблонаПервогоПоля = СтрДлина(ШаблонПервогоПоля);
	Если Сред(Запись, ПозицияНачала, ДлинаШаблонаПервогоПоля) = ШаблонПервогоПоля Тогда
		Возврат ПозицияНачала + ДлинаШаблонаПервогоПоля;
	КонецЕсли;
	
	ШаблонПоля = "," + ШаблонПервогоПоля;
	ПозицияПоля = СтрНайти(Запись, ШаблонПоля,, ПозицияНачала);
	Если ПозицияПоля = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат ПозицияПоля + СтрДлина(ШаблонПоля);
	
КонецФункции

&НаСервере
Функция ПрочитатьЗначениеПоляРазбора(Запись, НачальнаяПозиция)
	
	ДлинаЗаписи = СтрДлина(Запись);
	Если НачальнаяПозиция > ДлинаЗаписи Тогда
		Возврат "";
	КонецЕсли;
	
	ПервыйСимвол = Сред(Запись, НачальнаяПозиция, 1);
	Если ПервыйСимвол = "'" Или ПервыйСимвол = """" Тогда
		Кавычка = ПервыйСимвол;
		Позиция = НачальнаяПозиция + 1;
		НачалоЗначения = Позиция;
		Значение = "";
		
		Пока Позиция <= ДлинаЗаписи Цикл
			ПозицияКавычки = СтрНайти(Запись, Кавычка,, Позиция);
			Если ПозицияКавычки = 0 Тогда
				Возврат Значение + Сред(Запись, НачалоЗначения);
			КонецЕсли;
			
			Если ПозицияКавычки < ДлинаЗаписи И Сред(Запись, ПозицияКавычки + 1, 1) = Кавычка Тогда
				Значение = Значение + Сред(Запись, НачалоЗначения, ПозицияКавычки - НачалоЗначения + 1);
				Позиция = ПозицияКавычки + 2;
				НачалоЗначения = Позиция;
				Продолжить;
			Иначе
				Возврат Значение + Сред(Запись, НачалоЗначения, ПозицияКавычки - НачалоЗначения);
			КонецЕсли;
		КонецЦикла;
		
		Возврат Значение + Сред(Запись, НачалоЗначения);
	КонецЕсли;
	
	ПозицияЗапятой = СтрНайти(Запись, ",",, НачальнаяПозиция);
	Если ПозицияЗапятой = 0 Тогда
		Возврат СокрЛП(Сред(Запись, НачальнаяПозиция));
	КонецЕсли;
	
	Возврат СокрЛП(Сред(Запись, НачальнаяПозиция, ПозицияЗапятой - НачальнаяПозиция));
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСтрокиКонтекста(Поля, Контекст)
	
	ПерваяСтрока = "";
	ПоследняяСтрока = "";
	Контекст = СтрЗаменить(Контекст, Символы.ВК, Символы.ПС);
	Строки = СтрРазделить(Контекст, Символы.ПС, Ложь);
	
	Для Каждого СтрокаКонтекста Из Строки Цикл
		СтрокаКонтекста = СокрЛП(СтрокаКонтекста);
		Если ПустаяСтрока(СтрокаКонтекста) Тогда
			Продолжить;
		КонецЕсли;
		Если ПустаяСтрока(ПерваяСтрока) Тогда
			ПерваяСтрока = СтрокаКонтекста;
		КонецЕсли;
		ПоследняяСтрока = СтрокаКонтекста;
	КонецЦикла;
	
	Поля.Вставить("ПерваяСтрокаКонтекста", ПерваяСтрока);
	Поля.Вставить("МестоВызоваКонтекста", ПоследняяСтрока);
	
КонецПроцедуры

&НаСервере
Функция ОпределитьМестоВызова(ИмяСобытия, Поля)
	
	Контекст = Поля.Получить("Context");
	Если ЗначениеЗаполнено(Контекст) Тогда
		Возврат СокрЛП(ПоследняяСтрокаТекста(Контекст));
	КонецЕсли;
	
	Если ИмяСобытия = "CALL" Тогда
		МодульМетод = ПредставлениеМодуляИМетода(ЗначениеПоля(Поля, "Module"), ЗначениеПоля(Поля, "Method"));
		Если Не ПустаяСтрока(МодульМетод) Тогда
			Возврат СокрЛП(МодульМетод);
		КонецЕсли;
		Отчет = Поля.Получить("Report");
		Если Отчет <> Неопределено Тогда
			Возврат СокрЛП(Отчет);
		КонецЕсли;
		Возврат СокрЛП(ЗначениеПоля(Поля, "IName") + "." + ЗначениеПоля(Поля, "Method") + "." + ЗначениеПоля(Поля, "MName"));
	КонецЕсли;
	
	Если ИмяСобытия = "SDBL" Тогда
		Запрос = Поля.Получить("Sdbl");
		Если Запрос <> Неопределено Тогда
			Возврат СокрЛП(Запрос);
		КонецЕсли;
		Возврат СокрЛП(ЗначениеПоля(Поля, "Func") + " " + ЗначениеПоля(Поля, "tableName"));
	КонецЕсли;
	
	Если ИмяСобытия = "DBMSSQL" Тогда
		Запрос = Поля.Получить("Sql");
		Если Запрос <> Неопределено Тогда
			Возврат СокрЛП(Запрос);
		КонецЕсли;
		Возврат СокрЛП(ЗначениеПоля(Поля, "Func"));
	КонецЕсли;
	
	Если ИмяСобытия = "TLOCK" Тогда
		Возврат СокрЛП(ЗначениеПоля(Поля, "Regions") + " " + ЗначениеПоля(Поля, "Locks"));
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ПредставлениеМодуляИМетода(Модуль, Метод)
	
	Модуль = СокрЛП(Модуль);
	Метод = СокрЛП(Метод);
	
	Если Не ПустаяСтрока(Модуль) И Не ПустаяСтрока(Метод) Тогда
		Возврат Модуль + "." + Метод;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Модуль) Тогда
		Возврат Модуль;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ОпределитьЗапрос(ИмяСобытия, Поля)
	
	Если ИмяСобытия = "SDBL" Тогда
		Возврат ЗначениеПоля(Поля, "Sdbl");
	КонецЕсли;
	
	Если ИмяСобытия = "DBMSSQL" Тогда
		Возврат ЗначениеПоля(Поля, "Sql");
	КонецЕсли;
	
	Если ИмяСобытия = "TLOCK" Тогда
		Возврат ЗначениеПоля(Поля, "Locks");
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция КлючЗаписиТЖ(ЗаписьКэша)
	
	Возврат ЗаписьКэша.Файл + "|" + Формат(ЗаписьКэша.НомерСтроки, "ЧГ=0");
	
КонецФункции

&НаСервере
Функция КлючГруппировкиЗаписи(ЗаписьКэша)
	
	Возврат КлючГруппировки(ЗаписьКэша.ИмяСобытия, ЗаписьКэша.МестоВызова, ЗаписьКэша.Пользователь, ЗаписьКэша.Сеанс);
	
КонецФункции

&НаСервере
Функция КлючДочернейГруппировки(КлючРодителя, ЗаписьКэша)
	
	Возврат КлючРодителя + "|CHILD=" + КлючГруппировкиЗаписи(ЗаписьКэша);
	
КонецФункции

&НаСервере
Функция КлючГруппировки(ИмяСобытия, МестоВызова, Пользователь, Сеанс)
	
	Ключ = ИмяСобытия + "|" + МестоВызова;
	
	Если УчитыватьПользователейИСеансы Тогда
		Ключ = Ключ + "|USR=" + Пользователь + "|SESSION=" + Сеанс;
	КонецЕсли;
	
	Возврат Ключ;
	
КонецФункции

&НаСервере
Функция ЗначениеПоля(Поля, ИмяПоля)
	
	Значение = Поля.Получить(ИмяПоля);
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

&НаСервере
Функция ЧислоПоля(Значение)
	
	СтрокаЧисла = СокрЛП(Строка(Значение));
	Если ПустаяСтрока(СтрокаЧисла) Тогда
		Возврат 0;
	КонецЕсли;
	
	Если СтрНайти(СтрокаЧисла, ".") > 0 И СтрНайти(СтрокаЧисла, ",") = 0 Тогда
		СтрокаЧисла = СтрЗаменить(СтрокаЧисла, ".", ",");
	КонецЕсли;
	
	Попытка
		Возврат Число(СтрокаЧисла);
	Исключение
		Попытка
			Возврат Число(СтрЗаменить(СтрокаЧисла, ".", ","));
		Исключение
			Возврат 0;
		КонецПопытки;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ЭтоЦелевоеСобытие(ИмяСобытия)
	
	Возврат ИмяСобытия = "CALL"
		Или ИмяСобытия = "DBMSSQL"
		Или ИмяСобытия = "SDBL"
		Или ИмяСобытия = "TLOCK";
	
КонецФункции

